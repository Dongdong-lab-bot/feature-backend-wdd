# ============================================================
# 食安Agent集群 - 本地开发环境变量
# 复制此文件为 .env 后填写实际值，切勿将 .env 提交到Git仓库
# ============================================================

# --------------------------------------------------
# 项目基础配置
# --------------------------------------------------
PROJECT_NAME=food_safety_agent_cluster
ENV=dev
DEBUG=true
SERVICE_PORT=8000

# --------------------------------------------------
# MySQL配置 (不需要可留空)
# --------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=food_safety_agent
MYSQL_ADMIN_USER=
MYSQL_ADMIN_PASSWORD=
MYSQL_READONLY_USER=
MYSQL_READONLY_PASSWORD=

# --------------------------------------------------
# Redis配置 (不需要可留空)
# --------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
STREAM_TOPIC=agent_message_bus

# --------------------------------------------------
# ★★★ 大模型配置 — 填你自己的 LLM API ★★★
# --------------------------------------------------

# 你的 LLM API 地址
#   兼容 OpenAI 协议的 API 都支持，例如：
#   - DeepSeek:  https://api.deepseek.com/v1
#   - OpenRouter: https://openrouter.ai/api/v1
#   - 通义千问:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   - Ollama 本地: http://localhost:11434/v1
#   - 硅基流动:   https://api.siliconflow.cn/v1
# 如果留空，RouterService 会自动降级为关键词路由（无需LLM也能跑）
LLM_BASE_URL=https://api.deepseek.com/v1

# 你的 API Key（从 API 提供商处获取）
# ★ 在这里填入你的 DeepSeek API Key（从 platform.deepseek.com 获取）★
LLM_API_KEY=sk-941ecb651a714579992a8b47f3d6f042

# 模型名称，例如：
#   - DeepSeek:   deepseek-chat
#   - OpenRouter: openai/gpt-4o
#   - 通义千问:   qwen-plus
#   - Ollama:     qwen2.5:7b
#   - 硅基流动:   Qwen/Qwen2.5-7B-Instruct
# 如果留空，使用 LLM_BASE_URL 的默认模型
LLM_MODEL_NAME=deepseek-reasoner

# 大模型调用超时（秒）
LLM_TIMEOUT=60
# 调用失败重试次数
LLM_MAX_RETRIES=3

# --------------------------------------------------
# JWT认证 — 开发模式禁用验签
# --------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_DISABLE_VERIFY=true
JWT_ISSUER=
JWT_AUDIENCE=
